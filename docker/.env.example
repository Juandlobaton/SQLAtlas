# ── Database ─────────────────────────────────────────────────────
POSTGRES_USER=sqlatlas
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sqlatlas

# ── JWT ──────────────────────────────────────────────────────────
# IMPORTANT: Change this to a random string of 32+ characters
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars

# ── Credential Encryption ────────────────────────────────────────
# 32-byte hex key for encrypting stored database passwords
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

# Key rotation: set old key here when rotating. Remove after all credentials are re-accessed.
# CREDENTIAL_ENCRYPTION_KEY_PREVIOUS=

# ── Auth & Registration ──────────────────────────────────────────
# Registration mode: 'closed' (default), 'invite-only', 'open'
REGISTRATION_MODE=closed
# Multi-tenant mode: 'true' or 'false' (default)
MULTI_TENANT=false

# ── Auto-setup (optional) ───────────────────────────────────────
# If set, automatically creates admin user on first boot (no wizard needed)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=ChangeMe!Str0ng#
# ADMIN_DISPLAY_NAME=Admin
# ORG_NAME=My Organization

# ── Ports (host:container) ───────────────────────────────────────
API_PORT=3000
WEB_PORT=5173
PARSER_PORT=8100
DB_PORT=5433
REDIS_PORT=6380

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
