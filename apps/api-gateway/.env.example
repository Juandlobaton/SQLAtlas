# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database (app metadata)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=sqlatlas
DB_PASSWORD=changeme
DB_DATABASE=sqlatlas

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Parsing Engine
PARSING_ENGINE_URL=http://localhost:8100
PARSING_ENGINE_API_KEY=

# Redis (cache layer — runs on port 6380 in docker-compose)
REDIS_HOST=localhost
REDIS_PORT=6380

# Credential storage backend: 'aes' (default), 'vault', or 'aws'
CREDENTIAL_BACKEND=aes

# Required when CREDENTIAL_BACKEND=aes: 32-byte hex key for encrypting database credentials
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

# Key rotation: set the old key here when rotating to a new CREDENTIAL_ENCRYPTION_KEY.
# Credentials encrypted with the old key will be automatically re-encrypted on access.
# Remove this after all credentials have been accessed at least once.
# CREDENTIAL_ENCRYPTION_KEY_PREVIOUS=

# === HashiCorp Vault (when CREDENTIAL_BACKEND=vault) ===
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=
# VAULT_MOUNT_PATH=secret
# VAULT_PATH_PREFIX=sqlatlas/credentials

# === AWS Secrets Manager (when CREDENTIAL_BACKEND=aws) ===
# AWS_REGION=us-east-1
# AWS_SECRET_PREFIX=sqlatlas/credentials

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Setup & Auth ────────────────────────────────────────────────
# Registration mode: 'closed' (default), 'invite-only', or 'open'
#   closed      — only admins can create users (recommended for self-hosted)
#   invite-only — admins generate invite links
#   open        — anyone can register (SaaS-style)
REGISTRATION_MODE=closed

# Multi-tenant mode (default: false)
# When false, login doesn't require organization slug (single-org deployment)
MULTI_TENANT=false

# ── Mock OAuth (local dev — simulates Microsoft SSO without a real tenant) ──
# Set to 'true' to enable the built-in mock OAuth server.
# Shows a consent page at /api/v1/mock-oauth/authorize with mock users.
# MOCK_OAUTH=true

# ── Microsoft Entra ID (Azure AD) SSO ───────────────────────────
# Leave AZURE_AD_CLIENT_ID empty to disable Microsoft SSO.
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=common
# AZURE_AD_REDIRECT_URI=http://localhost:3000/api/v1/auth/microsoft/callback
# AZURE_AD_SCOPES=openid profile email
# AZURE_AD_AUTO_PROVISION=true
# AZURE_AD_DEFAULT_ROLE=analyst

# ── Auto-setup (for Docker/CI deploys) ──────────────────────────
# If set, the first boot automatically creates this admin user + org
# when the database is empty (no wizard needed).
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=ChangeMe!Str0ng#
# ADMIN_DISPLAY_NAME=Admin
# ORG_NAME=My Organization
