{
  "name": "@sqlatlas/api-gateway",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:cov": "jest --coverage",
    "db:migrate": "npx ts-node --project tsconfig.json ./node_modules/typeorm/cli.js migration:run -d src/infrastructure/persistence/data-source.ts",
    "db:migrate:revert": "npx ts-node --project tsconfig.json ./node_modules/typeorm/cli.js migration:revert -d src/infrastructure/persistence/data-source.ts",
    "db:migrate:generate": "npx ts-node --project tsconfig.json ./node_modules/typeorm/cli.js migration:generate -d src/infrastructure/persistence/data-source.ts",
    "db:seed": "ts-node src/infrastructure/persistence/seeds/run.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.2",
    "@nestjs/cache-manager": "^2.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@sqlatlas/shared-types": "workspace:*",
    "bcrypt": "^5.1.0",
    "cache-manager": "^5.0.0",
    "cache-manager-ioredis-yet": "^2.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "mssql": "^12.2.1",
    "oracledb": "^6.10.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  }
}
